# HCMOS deploy environment — COPY to /etc/hcmos/hcmos.env, fill with REAL secrets,
# chmod 600, owned by the service user. NEVER commit the filled file.
# Rotate every value away from the seed/sandbox defaults before go-live.

# --- Runtime -----------------------------------------------------------------
NODE_ENV=production          # disables the NODE_ENV-gated test fault seams
PORT=3000                    # bound behind the reverse proxy / tunnel; not public

# --- Database (in-region Postgres on localhost; scram-sha-256, TLS) -----------
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=hcmos
PGSSLMODE=require            # require|verify-full (+ PGSSLROOTCERT for verify-full)
# PGSSLROOTCERT=/etc/hcmos/pg-ca.crt

PG_OWNER=hcmos_owner
PG_OWNER_PW=__set_a_strong_unique_secret__   # runs migrations/seed
PG_APP=hcmos_app
PG_APP_PW=__set_a_different_strong_secret__   # the app role (non-superuser, RLS)

# --- Backups (in-region object storage; see deploy/backup.sh) ----------------
BACKUP_TARGET=s3://hcmos-uat-backups/pg        # rclone/aws remote, in-region bucket
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_DEFAULT_REGION via the secret store
